# - resource -------------------------------------------------------------------

<https://globalalliantinc.com/access/Condition/ESRDConditionExample> a fhir:Condition ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "ESRDConditionExample"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "https://globalalliantinc.com/access/StructureDefinition/access-clinical-exclusion-condition"^^xsd:anyURI ;
       fhir:l <https://globalalliantinc.com/access/StructureDefinition/access-clinical-exclusion-condition>
     ] )
  ] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">End stage renal disease (ESRD)</div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:clinicalStatus [
     fhir:coding ( [
       fhir:system [
         fhir:v "http://terminology.hl7.org/CodeSystem/condition-clinical"^^xsd:anyURI ;
         fhir:l <http://terminology.hl7.org/CodeSystem/condition-clinical>
       ] ;
       fhir:code [ fhir:v "active" ] ;
       fhir:display [ fhir:v "Active" ]
     ] )
  ] ; # 
  fhir:verificationStatus [
     fhir:coding ( [
       fhir:system [
         fhir:v "http://terminology.hl7.org/CodeSystem/condition-ver-status"^^xsd:anyURI ;
         fhir:l <http://terminology.hl7.org/CodeSystem/condition-ver-status>
       ] ;
       fhir:code [ fhir:v "confirmed" ] ;
       fhir:display [ fhir:v "Confirmed" ]
     ] )
  ] ; # 
  fhir:category ( [
     fhir:coding ( [
       fhir:system [
         fhir:v "http://terminology.hl7.org/CodeSystem/condition-category"^^xsd:anyURI ;
         fhir:l <http://terminology.hl7.org/CodeSystem/condition-category>
       ] ;
       fhir:code [ fhir:v "problem-list-item" ] ;
       fhir:display [ fhir:v "Problem List Item" ]
     ] )
  ] ) ; # 
  fhir:code [
     fhir:coding ( [
       fhir:system [
         fhir:v "http://hl7.org/fhir/sid/icd-10-cm"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/sid/icd-10-cm>
       ] ;
       fhir:code [ fhir:v "N18.6" ] ;
       fhir:display [ fhir:v "End stage renal disease" ]
     ] )
  ] ; # 
  fhir:subject [
     fhir:l <https://globalalliantinc.com/access/Patient/PatientESRDExample> ;
     fhir:reference [ fhir:v "Patient/PatientESRDExample" ]
  ] ; # 
  fhir:onset [
     a fhir:DateTime ;
     fhir:v "2026-01-15"^^xsd:date
  ] . # 

