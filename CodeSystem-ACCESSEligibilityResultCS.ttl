  fhir:concept ( [
     fhir:code [ fhir:v "eligible" ] ;
     fhir:display [ fhir:v "Eligible" ] ;
     fhir:definition [ fhir:v "Patient is eligible for services under the model. This response does not mean the patient has been aligned. It simply means the patient is eligible to be aligned." ]
  ] [
     fhir:code [ fhir:v "eligible-pending-diagnosis" ] ;
     fhir:display [ fhir:v "Eligible pending diagnosis" ] ;
     fhir:definition [ fhir:v "Patient is provisionally eligible for services under the model depending on the diagnosis." ]
  ] [
     fhir:code [ fhir:v "eligible-switch-participants" ] ;
     fhir:display [ fhir:v "Eligible to switch participants." ] ;
     fhir:definition [ fhir:v "Patient is eligible to switch participants." ]
  ] [
     fhir:code [ fhir:v "not-eligible-not-medicare" ] ;
     fhir:display [ fhir:v "Not eligible - not receiving Medicare" ] ;
     fhir:definition [ fhir:v "The patient either is not enrolled in Medicare Part A and Part B or dual eligible for Medicare and Medicaid, or they do not have Medicare as their primary insurance, so they are not eligible for services under the ACCESS Model." ]
  ] [
     fhir:code [ fhir:v "not-eligible-services" ] ;
     fhir:display [ fhir:v "Not eligible - receiving services that prevent eligibility" ] ;
     fhir:definition [ fhir:v "The patient is receiving services (such as hospice, end stage renal disease (ESRD), etc.) making them ineligible to be part of the ACCESS Model." ]
  ] [
     fhir:code [ fhir:v "not-eligible-diagnoses" ] ;
     fhir:display [ fhir:v "Not eligible - no qualifying diagnosis" ] ;
     fhir:definition [ fhir:v "The patient does not have a treating diagnosis that qualifies them for services in the track indicated and therefore cannot get services under the ACCESS Model." ]
  ] [
     fhir:code [ fhir:v "not-eligible-control-group" ] ;
     fhir:display [ fhir:v "Not eligible - assigned to Control Group" ] ;
     fhir:definition [ fhir:v "The patient is technically eligible for the ACCESS Model, but based on the randomized control group algorithm, the patient has been placed in the control group for 12 months and therefore cannot be aligned for 12 months." ]
  ] [
     fhir:code [ fhir:v "not-eligible-already-aligned" ] ;
     fhir:display [ fhir:v "Not eligible - already aligned to another participant in the track" ] ;
     fhir:definition [ fhir:v "The patient is technically eligible, but is already aligned to another participant and receiving services under the ACCESS Model in the same track. A patient can only be aligned to one participant in each track." ]
  ] ) . # 

