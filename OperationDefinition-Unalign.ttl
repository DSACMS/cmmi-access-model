     fhir:min [ fhir:v 1 ] ;
     fhir:max [ fhir:v "1" ] ;
     fhir:documentation [ fhir:v "Patient information.  It **SHOULD** contain the Medicare Beneficiary Identifier (MBI)." ] ;
     fhir:type [ fhir:v "Patient" ]
  ] [
