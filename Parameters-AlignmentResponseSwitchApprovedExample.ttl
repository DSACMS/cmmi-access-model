# - resource -------------------------------------------------------------------

<https://globalalliantinc.com/access/Parameters/AlignmentResponseSwitchApprovedExample> a fhir:Parameters ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "AlignmentResponseSwitchApprovedExample"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "https://globalalliantinc.com/access/StructureDefinition/access-align-out"^^xsd:anyURI ;
       fhir:l <https://globalalliantinc.com/access/StructureDefinition/access-align-out>
     ] )
  ] ; # 
  fhir:parameter ( [
     fhir:name [ fhir:v "result" ] ;
     fhir:value [
       a fhir:CodeableConcept ;
       fhir:coding ( [
         fhir:system [
           fhir:v "https://globalalliantinc.com/access/CodeSystem/ACCESSAlignmentResultCS"^^xsd:anyURI ;
           fhir:l <https://globalalliantinc.com/access/CodeSystem/ACCESSAlignmentResultCS>
         ] ;
         fhir:code [ fhir:v "aligned-switch-approved" ] ;
         fhir:display [ fhir:v "Aligned and switch approved" ]
       ] ) ;
       fhir:text [ fhir:v "The request to switch the patient's alignment from a different provider after the 3-month lock in period is accepted and the patient is considered switched and now re-aligned." ]
     ]
  ] ) . # 

