# - resource -------------------------------------------------------------------

<https://globalalliantinc.com/access/Parameters/UnalignmentResponseUnalignedExample> a fhir:Parameters ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "UnalignmentResponseUnalignedExample"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "https://globalalliantinc.com/access/StructureDefinition/access-unalign-out"^^xsd:anyURI ;
       fhir:l <https://globalalliantinc.com/access/StructureDefinition/access-unalign-out>
     ] )
  ] ; # 
  fhir:parameter ( [
     fhir:name [ fhir:v "result" ] ;
     fhir:value [
       a fhir:CodeableConcept ;
       fhir:coding ( [
         fhir:system [
           fhir:v "https://globalalliantinc.com/access/CodeSystem/ACCESSUnalignmentResultCS"^^xsd:anyURI ;
           fhir:l <https://globalalliantinc.com/access/CodeSystem/ACCESSUnalignmentResultCS>
         ] ;
         fhir:code [ fhir:v "unaligned" ] ;
         fhir:display [ fhir:v "Unaligned" ]
       ] ) ;
       fhir:text [ fhir:v "The request to manually unalign the patient has been successfully accepted and the patient has been successfully unaligned." ]
     ]
  ] ) . # 

