@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<https://globalalliantinc.com/access/Organization/OrganizationExample> a fhir:Organization ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "OrganizationExample"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://hl7.org/fhir/us/core/StructureDefinition/us-core-organization|6.1.0"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/us/core/StructureDefinition/us-core-organization?version=6.1.0>
     ] )
  ] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">Example Healthcare Organization, ACCESS Participant ID: ACCESS1234</div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:identifier ( [
     fhir:system [
       fhir:v "https://globalalliantinc.com/access/participant-id"^^xsd:anyURI ;
       fhir:l <https://globalalliantinc.com/access/participant-id>
     ] ;
     fhir:value [ fhir:v "ACCESS1234" ]
  ] ) ; # 
  fhir:active [ fhir:v true] ; # 
  fhir:name [ fhir:v "Example Healthcare Organization"] . # 

