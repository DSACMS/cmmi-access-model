  fhir:content [ fhir:v "complete"] ; # 
  fhir:count [ fhir:v "7"^^xsd:nonNegativeInteger] ; # 
  fhir:concept ( [
     fhir:code [ fhir:v "aligned" ] ;
     fhir:display [ fhir:v "Aligned" ] ;
     fhir:definition [ fhir:v "Patient is eligible and has been aligned so the participant can now begin providing services to the patient under the ACCESS Model." ]
  ] [
     fhir:code [ fhir:v "not-aligned-control-group" ] ;
     fhir:display [ fhir:v "Not aligned - assigned to Control Group" ] ;
     fhir:definition [ fhir:v "The patient is technically eligible, but based on the randomized control group algorithm, the patient has been placed in the control group for 12 months and therefore cannot be aligned for 12 months." ]
  ] [
     fhir:code [ fhir:v "not-aligned-already-aligned" ] ;
     fhir:display [ fhir:v "Not aligned - already aligned to another participant in the track" ] ;
     fhir:definition [ fhir:v "The patient is technically eligible, but is already aligned to another participant and receiving services under the ACCESS Model in the same track. A patient can only be aligned to one participant in each track. If a switch consent attestation is submitted, but the patient is still within the 3-month lock-in period, this response will be received." ]
  ] [
     fhir:code [ fhir:v "not-aligned-not-medicare" ] ;
     fhir:display [ fhir:v "Not aligned - not receiving Medicare" ] ;
     fhir:definition [ fhir:v "The patient either is not enrolled in Medicare Part A and Part B or dual eligible for Medicare and Medicaid, or they do not have Medicare as their primary insurance, so they are not eligible for services under the ACCESS Model." ]
  ] [
     fhir:code [ fhir:v "not-aligned-services" ] ;
     fhir:display [ fhir:v "Not aligned - receiving services that prevent eligibility" ] ;
     fhir:definition [ fhir:v "The patient is receiving services (such as hospice, end stage renal disease (ESRD), etc.) making them ineligible to be part of the ACCESS Model." ]
  ] [
     fhir:code [ fhir:v "not-aligned-diagnoses" ] ;
     fhir:display [ fhir:v "Not aligned - no qualifying diagnosis" ] ;
     fhir:definition [ fhir:v "The patient does not have a treating diagnosis that qualifies them for service in the track indicated and therefore cannot get services under the ACCESS Model." ]
  ] [
     fhir:code [ fhir:v "aligned-switch-approved" ] ;
     fhir:display [ fhir:v "Aligned and switch approved" ] ;
     fhir:definition [ fhir:v "The request to switch the patient's alignment from a different participant after the 3-month lock in period is accepted and the patient is considered switched and now re-aligned." ]
  ] ) . # 

