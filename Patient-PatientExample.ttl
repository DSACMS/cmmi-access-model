@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<https://globalalliantinc.com/access/Patient/PatientExample> a fhir:Patient ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "PatientExample"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://hl7.org/fhir/us/core/StructureDefinition/us-core-patient|6.1.0"^^xsd:anyURI ;
       fhir:l <http://hl7.org/fhir/us/core/StructureDefinition/us-core-patient?version=6.1.0>
     ] )
  ] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">Patient John Doe, male, born 1950-01-01, Medicare ID: 1EG4TE5MK73</div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:identifier ( [
     fhir:type [
       fhir:coding ( [
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/v2-0203"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/v2-0203>
         ] ;
         fhir:code [ fhir:v "MC" ]
       ] )
     ] ;
     fhir:system [
       fhir:v "http://terminology.hl7.org/NamingSystem/cmsMBI"^^xsd:anyURI ;
       fhir:l <http://terminology.hl7.org/NamingSystem/cmsMBI>
     ] ;
     fhir:value [ fhir:v "1EG4TE5MK73" ]
  ] ) ; # 
  fhir:name ( [
     fhir:family [ fhir:v "Doe" ] ;
     fhir:given ( [ fhir:v "John" ] )
  ] ) ; # 
  fhir:gender [ fhir:v "male"] ; # 
  fhir:birthDate [ fhir:v "1950-01-01"^^xsd:date] . # 

