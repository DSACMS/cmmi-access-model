  ] ) ; # 
  fhir:rest ( [
     fhir:mode [ fhir:v "server" ] ;
     fhir:documentation [ fhir:v "The ACCESS Unalignment API supports the voluntary removal of patient alignments from ACCESS participants and tracks." ] ;
     fhir:security [
       fhir:cors [ fhir:v true ] ;
       fhir:description [ fhir:v "Implementations SHALL use TLS 1.3 and implement OAuth 2.0 Client Credentials flow for authentication. MBI and other PHI must be protected according to HIPAA requirements." ]
     ] ;
     fhir:resource ( [
       fhir:type [ fhir:v "Patient" ] ;
       fhir:documentation [ fhir:v "Patient resource for ACCESS unalignment operations" ] ;
       fhir:operation ( [
         fhir:name [ fhir:v "unalign" ] ;
         fhir:definition [
           fhir:v "https://globalalliantinc.com/access/OperationDefinition/Unalign|0.9.0"^^xsd:anyURI ;
           fhir:l <https://globalalliantinc.com/access/OperationDefinition/Unalign?version=0.9.0>
         ] ;
         fhir:documentation [ fhir:v "Remove a patient's alignment from an ACCESS participant. Requires mandatory reason parameter from ACCESSUnalignmentReasonVS (geographic-relocated or loss-of-contact). Automatically cancels active subscriptions and sends unalignment notifications upon successful unalignment. Returns unalignment status from ACCESSUnalignmentResultVS: unaligned or unalignment-pending. Implements asynchronous processing with HTTP 202 Accepted response containing Content-Location header for status polling." ]
       ] [
         fhir:name [ fhir:v "submission-status" ] ;
         fhir:definition [
           fhir:v "https://globalalliantinc.com/access/OperationDefinition/SubmissionStatus|0.9.0"^^xsd:anyURI ;
           fhir:l <https://globalalliantinc.com/access/OperationDefinition/SubmissionStatus?version=0.9.0>
         ] ;
         fhir:documentation [ fhir:v "Poll the status of a previously submitted unalignment request. Returns HTTP 202 while processing or HTTP 200 with result when complete." ]
       ] )
     ] )
